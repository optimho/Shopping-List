{
  "name": "shopping-list",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --hot server.ts",
    "build:client": "bun build src/main.tsx --outdir public --target browser --sourcemap",
    "build:css": "~/.bun/bin/bunx @tailwindcss/cli -i src/globals.css -o public/globals.css",
    "build": "bun run build:client && bun run build:css",
    "init-db": "bun scripts/init-db.ts",
    "seed-admin": "bun scripts/seed-admin.ts"
  },
  "dependencies": {
    "better-auth": "^1.6.11",
    "fflate": "^0.8.3",
    "hono": "^4",
    "nanoid": "^5.1.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@types/node": "^25.8.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.14",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
